# CAUSA — Variáveis de ambiente
# Copie este arquivo para .env e preencha os valores

# Topologia: "solo" ou "escritorio"
CAUSA_TOPOLOGIA=solo

# Banco de dados (modo escritório)
# DATABASE_URL=postgresql://causa:senha@192.168.1.100:5432/causa

# Porta da API local do serviço Windows
CAUSA_SERVICE_PORT=9473

# Intervalo de sincronização dos conectores (minutos)
CAUSA_SYNC_INTERVAL=30

# Modo de desenvolvimento
NODE_ENV=development
